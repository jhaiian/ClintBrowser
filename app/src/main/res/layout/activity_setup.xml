<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_dark">

    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@android:anim/slide_in_left"
        android:outAnimation="@android:anim/slide_out_right">

        <!-- PAGE 0: Terms & Privacy Consent -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginTop="32dp"
                    android:src="@drawable/ic_clint_logo"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Welcome to Clint"
                    android:textColor="@color/on_surface"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"
                    android:text="Before you get started, please review our terms."
                    android:textColor="@color/on_surface_medium"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="4dp"
                            android:paddingBottom="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_shield_24"
                                android:alpha="0.7" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Privacy Policy"
                                android:textColor="@color/on_surface"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvConsentPrivacyLink"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Read"
                                android:textColor="@color/purple_300"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium"
                                android:background="?attr/selectableItemBackground"
                                android:padding="4dp" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#12FFFFFF" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="12dp"
                            android:paddingBottom="4dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_info_24"
                                android:alpha="0.7" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Terms of Service"
                                android:textColor="@color/on_surface"
                                android:textSize="15sp"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/tvConsentTermsLink"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Read"
                                android:textColor="@color/purple_300"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-medium"
                                android:background="?attr/selectableItemBackground"
                                android:padding="4dp" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkboxConsent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/purple_300" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="I have read and agree to the Privacy Policy and Terms of Service"
                        android:textColor="@color/on_surface_medium"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAgreeAndContinue"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="24dp"
                    android:text="Agree &amp; Continue"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:enabled="false"
                    app:backgroundTint="@color/purple_500"
                    app:cornerRadius="26dp" />

            </LinearLayout>
        </ScrollView>

        <!-- PAGE 1: Search Engine -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginTop="24dp"
                    android:src="@drawable/ic_clint_logo"
                    android:contentDescription="@string/app_name" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/app_name"
                    android:textColor="@color/on_surface"
                    android:textSize="32sp"
                    android:letterSpacing="0.04"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/setup_subtitle"
                    android:textColor="@color/on_surface_medium"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="36dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/choose_search_engine"
                    android:textColor="@color/purple_200"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDuckduckgo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/purple_300"
                    app:strokeWidth="3dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <RadioButton
                            android:id="@+id/radioDuckduckgo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="@color/purple_300"
                            android:clickable="false"
                            android:focusable="false" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/engine_duckduckgo"
                                android:textColor="@color/on_surface"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/engine_duckduckgo_desc"
                                android:textColor="@color/on_surface_medium"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/default_label"
                            android:textColor="@color/purple_300"
                            android:textSize="11sp"
                            android:background="@drawable/chip_background"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBrave"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:alpha="0.45"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/purple_300"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <RadioButton
                            android:id="@+id/radioBrave"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/purple_300"
                            android:clickable="false"
                            android:focusable="false" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/engine_brave"
                                android:textColor="@color/on_surface"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/engine_brave_desc"
                                android:textColor="@color/on_surface_medium"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:alpha="0.45"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/purple_300"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <RadioButton
                            android:id="@+id/radioGoogle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/purple_300"
                            android:clickable="false"
                            android:focusable="false" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/engine_google"
                                android:textColor="@color/on_surface"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-medium" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/engine_google_desc"
                                android:textColor="@color/on_surface_medium"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/next"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/purple_500"
                    app:cornerRadius="26dp" />

            </LinearLayout>
        </ScrollView>

        <!-- PAGE 2: DNS over HTTPS -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/doh_setup_title"
                    android:textColor="@color/on_surface"
                    android:textSize="26sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/doh_description"
                    android:textColor="@color/on_surface_medium"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/doh_mode_label"
                    android:textColor="@color/purple_200"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDohOff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/purple_300"
                    app:strokeWidth="3dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <RadioButton android:id="@+id/radioDohSetupOff" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:buttonTint="@color/purple_300" android:clickable="false" android:focusable="false" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_off" android:textColor="@color/on_surface" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_off_desc" android:textColor="@color/on_surface_medium" android:textSize="12sp" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDohDefault"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.45"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/purple_300"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <RadioButton android:id="@+id/radioDohSetupDefault" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/purple_300" android:clickable="false" android:focusable="false" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_default" android:textColor="@color/on_surface" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_default_desc" android:textColor="@color/on_surface_medium" android:textSize="12sp" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDohIncreased"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.45"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/purple_300"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <RadioButton android:id="@+id/radioDohSetupIncreased" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/purple_300" android:clickable="false" android:focusable="false" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_increased" android:textColor="@color/on_surface" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_increased_desc" android:textColor="@color/on_surface_medium" android:textSize="12sp" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDohMax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:alpha="0.45"
                    app:cardBackgroundColor="@color/toolbar_color"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/purple_300"
                    app:strokeWidth="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <RadioButton android:id="@+id/radioDohSetupMax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/purple_300" android:clickable="false" android:focusable="false" />
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_max" android:textColor="@color/on_surface" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_mode_max_desc" android:textColor="@color/on_surface_medium" android:textSize="12sp" android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/setupProviderSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="@string/doh_provider_label"
                        android:textColor="@color/purple_200"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardSetupCloudflare"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:cardBackgroundColor="@color/toolbar_color"
                        app:cardCornerRadius="14dp"
                        app:strokeColor="@color/purple_300"
                        app:strokeWidth="3dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                            <RadioButton android:id="@+id/radioSetupCloudflare" android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" android:buttonTint="@color/purple_300" android:clickable="false" android:focusable="false" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_provider_cloudflare" android:textColor="@color/on_surface" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_provider_cloudflare_desc" android:textColor="@color/on_surface_medium" android:textSize="12sp" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardSetupQuad9"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:alpha="0.45"
                        app:cardBackgroundColor="@color/toolbar_color"
                        app:cardCornerRadius="14dp"
                        app:strokeColor="@color/purple_300"
                        app:strokeWidth="0dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                            <RadioButton android:id="@+id/radioSetupQuad9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:buttonTint="@color/purple_300" android:clickable="false" android:focusable="false" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_provider_quad9" android:textColor="@color/on_surface" android:textSize="15sp" android:fontFamily="sans-serif-medium" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/doh_provider_quad9_desc" android:textColor="@color/on_surface_medium" android:textSize="12sp" android:layout_marginTop="2dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGetStarted"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/get_started"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    app:backgroundTint="@color/purple_500"
                    app:cornerRadius="26dp" />

            </LinearLayout>
        </ScrollView>

    </ViewFlipper>

</LinearLayout>
