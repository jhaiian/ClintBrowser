<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/option_scroll_off"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/swatch_scroll_off"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:clipChildren="true">

            <View
                android:id="@+id/swatch_off_top"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="top" />

            <View
                android:id="@+id/swatch_off_pill"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="4dp"
                android:alpha="0.35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="22dp" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
            </LinearLayout>

            <View
                android:id="@+id/swatch_off_bottom"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom" />

            <LinearLayout
                android:id="@+id/swatch_off_nav_dots"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal"
                android:visibility="gone">
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_off" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_off_desc" android:textSize="13sp" android:textColor="?attr/colorOnSurface" android:alpha="0.65" android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView android:id="@+id/check_scroll_off" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_check_24" android:tint="?attr/colorPrimary" />
    </LinearLayout>

    <View android:id="@+id/divider_after_off" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="84dp" android:layout_marginEnd="16dp" android:background="?attr/colorOnSurface" android:alpha="0.08" />

    <LinearLayout
        android:id="@+id/option_scroll_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/swatch_scroll_top"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:clipChildren="true">

            <View
                android:id="@+id/swatch_top_top"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="top" />

            <View
                android:id="@+id/swatch_top_pill"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="4dp"
                android:alpha="0.35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="22dp" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
            </LinearLayout>

            <View
                android:id="@+id/swatch_top_bottom"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom" />

            <LinearLayout
                android:id="@+id/swatch_top_nav_dots"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal"
                android:visibility="gone">
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_search_bar" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_search_bar_desc" android:textSize="13sp" android:textColor="?attr/colorOnSurface" android:alpha="0.65" android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView android:id="@+id/check_scroll_top" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_check_24" android:tint="?attr/colorPrimary" />
    </LinearLayout>

    <View android:id="@+id/divider_after_top" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="84dp" android:layout_marginEnd="16dp" android:background="?attr/colorOnSurface" android:alpha="0.08" />

    <LinearLayout
        android:id="@+id/option_scroll_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/swatch_scroll_bottom"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:clipChildren="true">

            <View
                android:id="@+id/swatch_bottom_top"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="top" />

            <View
                android:id="@+id/swatch_bottom_pill"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="4dp"
                android:alpha="0.35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="22dp" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
            </LinearLayout>

            <View
                android:id="@+id/swatch_bottom_bottom"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom" />

            <LinearLayout
                android:id="@+id/swatch_bottom_nav_dots"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal"
                android:visibility="gone">
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:layout_marginEnd="8dp">
            <TextView android:id="@+id/title_scroll_bottom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_nav_bar" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
            <TextView android:id="@+id/desc_scroll_bottom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_nav_bar_desc" android:textSize="13sp" android:textColor="?attr/colorOnSurface" android:alpha="0.65" android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView android:id="@+id/check_scroll_bottom" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_check_24" android:tint="?attr/colorPrimary" />
    </LinearLayout>

    <View android:id="@+id/divider_after_bottom" android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="84dp" android:layout_marginEnd="16dp" android:background="?attr/colorOnSurface" android:alpha="0.08" />

    <LinearLayout
        android:id="@+id/option_scroll_both"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/swatch_scroll_both"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:clipChildren="true">

            <View
                android:id="@+id/swatch_both_top"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="top" />

            <View
                android:id="@+id/swatch_both_pill"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="4dp"
                android:alpha="0.35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="22dp" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
            </LinearLayout>

            <View
                android:id="@+id/swatch_both_bottom"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom" />

            <LinearLayout
                android:id="@+id/swatch_both_nav_dots"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal"
                android:visibility="gone">
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_both" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/nested_scroll_both_desc" android:textSize="13sp" android:textColor="?attr/colorOnSurface" android:alpha="0.65" android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView android:id="@+id/check_scroll_both" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_check_24" android:tint="?attr/colorPrimary" />
    </LinearLayout>

</LinearLayout>
