<?xml version="1.0" encoding="utf-8"?>
<com.jhaiian.clint.downloads.DownloadProgressCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/download_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    android:layout_marginTop="3dp"
    android:layout_marginBottom="3dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/clintCardBackground"
    app:cardCornerRadius="14dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="40dp">

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <ImageView
                    android:id="@+id/download_type_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_file_other_24"
                    android:tint="?attr/clintSecondaryTextColor"
                    android:contentDescription="@string/download_icon_desc"
                    android:scaleType="fitCenter" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/download_filename"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:ellipsize="middle" />

                    <TextView
                        android:id="@+id/download_resumable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="?attr/clintSecondaryTextColor"
                        android:textSize="10sp"
                        android:maxLines="1"
                        android:visibility="gone" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/download_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="?attr/clintSecondaryTextColor"
                        android:textSize="10sp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/download_meta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:textColor="?attr/clintSecondaryTextColor"
                        android:textSize="10sp"
                        android:gravity="end"
                        android:maxLines="1"
                        android:visibility="gone" />

                </LinearLayout>

                <TextView
                    android:id="@+id/download_retry_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:textColor="?attr/clintSecondaryTextColor"
                    android:textSize="10sp"
                    android:lineSpacingMultiplier="1.3"
                    android:visibility="gone" />

            </LinearLayout>

            <ImageView
                android:id="@+id/download_pause"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_pause_24"
                android:padding="8dp"
                android:alpha="0.6"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/download_pause_desc"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/download_more"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_more_vert_24"
                android:padding="8dp"
                android:alpha="0.6"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/download_more_desc"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</com.jhaiian.clint.downloads.DownloadProgressCardView>
