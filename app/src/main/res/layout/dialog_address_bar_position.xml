<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/option_position_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/swatch_position_top"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:clipChildren="true">

            <View
                android:id="@+id/swatch_top_topbar"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="top" />

            <View
                android:id="@+id/swatch_top_pill"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="4dp"
                android:alpha="0.35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical">

                <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="22dp" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
            </LinearLayout>

        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/address_bar_position_top" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/address_bar_position_top_desc" android:textSize="13sp" android:textColor="?attr/colorOnSurface" android:alpha="0.65" android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView android:id="@+id/check_position_top" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_check_24" android:tint="?attr/colorPrimary" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="84dp" android:layout_marginEnd="16dp" android:background="?attr/colorOnSurface" android:alpha="0.08" />

    <LinearLayout
        android:id="@+id/option_position_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/swatch_position_bottom"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:clipChildren="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="8dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="22dp" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
            </LinearLayout>

            <View
                android:id="@+id/swatch_bottom_bottombar"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom" />

            <View
                android:id="@+id/swatch_bottom_pill"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="4dp"
                android:alpha="0.35" />

        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/address_bar_position_bottom" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/address_bar_position_bottom_desc" android:textSize="13sp" android:textColor="?attr/colorOnSurface" android:alpha="0.65" android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView android:id="@+id/check_position_bottom" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_check_24" android:tint="?attr/colorPrimary" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginStart="84dp" android:layout_marginEnd="16dp" android:background="?attr/colorOnSurface" android:alpha="0.08" />

    <LinearLayout
        android:id="@+id/option_position_split"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:id="@+id/swatch_position_split"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:clipChildren="true">

            <View
                android:id="@+id/swatch_split_topbar"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="top" />

            <View
                android:id="@+id/swatch_split_pill"
                android:layout_width="28dp"
                android:layout_height="5dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="4dp"
                android:alpha="0.35" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical">

                <View android:layout_width="match_parent" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="22dp" android:layout_height="3dp" android:layout_marginBottom="4dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
                <View android:layout_width="match_parent" android:layout_height="3dp" android:background="?attr/colorOnSurface" android:alpha="0.15" />
            </LinearLayout>

            <View
                android:id="@+id/swatch_split_bottombar"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:layout_gravity="bottom"
                android:orientation="horizontal"
                android:gravity="center_vertical|center_horizontal">

                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:layout_marginEnd="3dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
                <View android:layout_width="5dp" android:layout_height="5dp" android:background="?attr/colorOnSurface" android:alpha="0.25" />
            </LinearLayout>

        </FrameLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp" android:layout_marginEnd="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/address_bar_position_split" android:textSize="15sp" android:textStyle="bold" android:textColor="?attr/colorOnSurface" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/address_bar_position_split_desc" android:textSize="13sp" android:textColor="?attr/colorOnSurface" android:alpha="0.65" android:layout_marginTop="2dp" />
        </LinearLayout>

        <ImageView android:id="@+id/check_position_split" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_check_24" android:tint="?attr/colorPrimary" />
    </LinearLayout>

</LinearLayout>
