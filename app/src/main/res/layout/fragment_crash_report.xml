<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Crash Reports Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/crash_reports_title"
                android:textColor="@color/purple_200"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClearAll"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/crash_clear_all"
                android:textColor="@color/on_surface_medium"
                android:textSize="12sp"
                app:rippleColor="@color/purple_700" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvNoCrashes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crash_no_reports"
            android:textColor="@color/on_surface_medium"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/crashListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp" />

        <!-- Report Template Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crash_report_title"
            android:textColor="@color/purple_200"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/crash_report_instructions"
            android:textColor="@color/on_surface_medium"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="12dp" />

        <!-- Steps -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/toolbar_color"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/crash_steps_title"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/crash_steps"
                    android:textColor="@color/on_surface_medium"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Template -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/toolbar_color"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/crash_template_title"
                        android:textColor="@color/on_surface"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <ImageButton
                        android:id="@+id/btnCopyTemplate"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_copy_24"
                        android:tint="@color/purple_200"
                        android:contentDescription="@string/crash_copy_template" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvReportTemplate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface_medium"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenGithub"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="@string/crash_open_github"
            android:textSize="14sp"
            app:backgroundTint="@color/purple_700"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_github_24"
            app:iconSize="18dp"
            app:iconGravity="textStart" />

    </LinearLayout>
</ScrollView>
