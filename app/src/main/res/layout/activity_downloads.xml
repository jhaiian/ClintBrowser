<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:id="@+id/downloads_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back_24"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back" />

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="@string/downloads_title"
                android:textColor="?attr/colorOnSurface"
                android:textSize="19sp"
                android:fontFamily="sans-serif-medium" />

            <EditText
                android:id="@+id/search_edit_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:hint="@string/downloads_search_hint"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/clintSecondaryTextColor"
                android:textSize="16sp"
                android:background="@null"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:maxLines="1"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_search_close"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_close_24"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/clintIconTint"
                android:contentDescription="@string/downloads_search"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_search"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_search_24"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/clintIconTint"
                android:contentDescription="@string/downloads_search" />

            <ImageView
                android:id="@+id/btn_download_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_settings_24"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/clintIconTint"
                android:contentDescription="@string/download_settings_title" />

            <ImageView
                android:id="@+id/btn_sort"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_sort_24"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorPrimary"
                android:alpha="0.85"
                android:contentDescription="@string/downloads_sort" />

            <ImageView
                android:id="@+id/btn_selection_options"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_checklist_24"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorPrimary"
                android:alpha="0.85"
                android:contentDescription="@string/downloads_more_options"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/btn_multi_item_options"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_more_horiz_24"
                android:padding="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="?attr/colorPrimary"
                android:alpha="0.85"
                android:contentDescription="@string/download_multi_options_desc"
                android:visibility="gone" />

        </LinearLayout>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/downloads_tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:tabMode="auto"
            app:tabGravity="fill"
            app:tabIndicatorFullWidth="false" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/downloads_view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_add_download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_add_24"
            android:contentDescription="@string/download_manual_fab_desc"
            app:backgroundTint="?attr/clintButtonBackground"
            app:tint="?attr/clintButtonIconTint"
            app:fabSize="normal" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_delete_24"
            android:contentDescription="@string/downloads_delete_selected_desc"
            app:backgroundTint="?attr/clintButtonBackground"
            app:tint="?attr/clintButtonIconTint"
            app:fabSize="normal"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
