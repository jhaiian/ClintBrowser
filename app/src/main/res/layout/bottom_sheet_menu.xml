<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/clintPopupBackground"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/nav_icons_row_sheet"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/sheet_btn_back"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back_24"
            android:tint="?attr/clintIconTint"
            android:contentDescription="@string/back" />

        <ImageButton
            android:id="@+id/sheet_btn_forward"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_forward_24"
            android:tint="?attr/clintIconTint"
            android:contentDescription="@string/forward" />

        <ImageButton
            android:id="@+id/sheet_btn_home"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_home_24"
            android:tint="?attr/clintIconTint"
            android:contentDescription="@string/home" />

        <ImageButton
            android:id="@+id/sheet_btn_refresh"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_refresh_24"
            android:tint="?attr/clintIconTint"
            android:contentDescription="@string/refresh" />

        <ImageButton
            android:id="@+id/sheet_btn_bookmark"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bookmark_24"
            android:tint="?attr/clintIconTint"
            android:contentDescription="@string/menu_bookmarks" />

    </LinearLayout>

    <View
        android:id="@+id/nav_icons_divider_sheet"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:background="?attr/clintDividerColor"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/sheet_menu_new_tab"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_add_24"
                android:tint="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/new_tab"
                android:textColor="?attr/colorOnSurface"
                android:textSize="11sp"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sheet_menu_incognito"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_incognito_24"
                android:tint="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/new_incognito_tab"
                android:textColor="?attr/colorOnSurface"
                android:textSize="11sp"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sheet_menu_share"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_share_24"
                android:tint="?attr/colorPrimary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/share_url"
                android:textColor="?attr/colorOnSurface"
                android:textSize="11sp"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/sheet_menu_open_in_app"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_open_in_new_24"
                android:tint="?attr/colorPrimary" />

            <TextView
                android:id="@+id/sheet_menu_open_in_app_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/menu_open_in_app"
                android:textColor="?attr/colorOnSurface"
                android:textSize="11sp"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:background="?attr/clintDividerColor" />

    <LinearLayout
        android:id="@+id/sheet_menu_downloads"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_download_24"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/menu_downloads"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/sheet_menu_bookmarks"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_bookmark_24"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/menu_bookmarks"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/clintDividerColor" />

    <LinearLayout
        android:id="@+id/sheet_menu_desktop_mode"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_desktop_24"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/desktop_mode"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/sheet_desktop_mode_check"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_24"
            android:alpha="0"
            android:tint="?attr/colorPrimary" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/clintDividerColor" />

    <LinearLayout
        android:id="@+id/sheet_menu_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_settings_24"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/settings"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp" />

    </LinearLayout>

</LinearLayout>
