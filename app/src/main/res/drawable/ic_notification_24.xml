<?xml version="1.0" encoding="utf-8"?>
<!--
    Status bar / notification small icon, derived from the Clint logo
    (drawable/ic_clint_logo.xml). Per Android notification guidelines, this
    must be a flat, single-color silhouette on a transparent background —
    the system only reads the alpha channel and renders it in white (or the
    theme color) in the status bar and notification shade, so color here is
    just a safe placeholder. Do not tint or recolor this drawable elsewhere;
    create a separate icon if this shape is needed in colored app UI.
-->
