<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ClintBrowser" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/dark_purple</item>
        <item name="colorSecondary">@color/purple_300</item>
        <item name="colorOnSecondary">@color/dark_purple</item>
        <item name="colorSurface">@color/toolbar_color</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="colorPrimaryContainer">@color/purple_700</item>
        <item name="colorOnPrimaryContainer">@color/purple_50</item>
        <item name="android:statusBarColor">@color/toolbar_color</item>
        <item name="android:navigationBarColor">@color/toolbar_color</item>
    </style>

    <style name="ClintDialogShape" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ClintDialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="ThemeOverlay.ClintBrowser.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/ClintDialogShape</item>
        <item name="colorSurface">@color/toolbar_color</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorPrimary">@color/purple_300</item>
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_medium</item>
        <item name="materialAlertDialogTitleTextStyle">@style/ClintDialogTitle</item>
    </style>
</resources>
